# LINE Messaging API の認証情報
# LINE Developers Console (https://developers.line.biz/) から取得してください

LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
OPENAI_API_KEY=your_openai_api_key_here

# 永続化ストレージ（任意）
# 未指定時は .data/warikan_store.json を使います
WARIKAN_STORAGE_PATH=.data/warikan_store.json

# LIFF (LINE Front-end Framework) - 入力フォーム用（任意）
# LINE Developers Console で LIFF アプリを作成し、LIFF ID を設定してください
# 未設定の場合はテキストベースのウィザードが使われます
LIFF_ID=
